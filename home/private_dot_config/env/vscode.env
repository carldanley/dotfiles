#!/usr/bin/env bash

path_add_once() {
  case ":$PATH:" in
    *":$1:"*) ;;
    *) export PATH="$1:$PATH" ;;
  esac
}

if [ -d "/Applications/Visual Studio Code.app/Contents/Resources/app/bin" ]; then
  path_add_once "/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
elif [ -d "$HOME/Applications/Visual Studio Code.app/Contents/Resources/app/bin" ]; then
  path_add_once "$HOME/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
fi

unset -f path_add_once
