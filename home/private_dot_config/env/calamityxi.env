#!/usr/bin/env bash

path_add_once() {
  case ":$PATH:" in
    *":$1:"*) ;;
    *) export PATH="$1:$PATH" ;;
  esac
}

calamityxi_bin_dir="$HOME/Code/personal/CalamityXI/dev-environment/bin"
if [ -d "$calamityxi_bin_dir" ]; then
  path_add_once "$calamityxi_bin_dir"
fi

unset calamityxi_bin_dir
unset -f path_add_once
